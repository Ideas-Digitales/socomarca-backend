###
# @prompt empresa
# @prompt koen
# @prompt tido
# @prompt modalidad
# @prompt cantidad
# @prompt codigoProducto
POST {{$dotenv RANDOM_ERP_URL}}/web32/documento?dryRun=true
Content-Type: application/json
Authorization: Bearer {{$dotenv RANDOM_ERP_TOKEN}}

{
  "datos": {
    "empresa": "{{empresa}}",
    "codigoEntidad": "{{koen}}",
    "tido": "{{tido}}",
    "modalidad": "{{modalidad}}",
    "lineas": [
      {
        "cantidad": "{{cantidad}}",
        "codigoProducto": "{{codigoProducto}}"
      }
    ]
  }
}